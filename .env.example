# Server-only Supabase credentials. Never prefix either value with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# 32 random bytes encoded as 64 hex characters.
API_KEY_ENCRYPTION_KEY=replace-with-64-hex-characters

# Canonical public origin used for strict same-origin mutation checks.
APP_ORIGIN=http://localhost:3000

# Number of trusted reverse-proxy hops that append X-Forwarded-For.
TRUSTED_PROXY_HOPS=1

# Local development only. Production refuses to use the local store.
SYNTHNET_DEMO_MODE=false
